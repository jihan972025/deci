<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#131313"
    tools:context=".MainActivity">

    <!-- Top App Bar -->
    <LinearLayout
        android:id="@+id/topAppBar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="#0A0A0A"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/toolbarTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DECI PRO"
            android:textColor="#CCFF00"
            android:textSize="18sp"
            android:fontFamily="@font/space_grotesk_bold"
            android:letterSpacing="-0.02" />
    </LinearLayout>

    <!-- Grid Mesh Background -->
    <com.deci.GridMeshView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintTop_toBottomOf="@id/topAppBar" />

    <!-- Main Content with Grid Background -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="#00000000"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintTop_toBottomOf="@id/topAppBar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="0dp">

            <!-- Primary Readout Module -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#0A0A0A"
                android:orientation="vertical"
                android:padding="12dp"
                android:layout_marginBottom="16dp">

                <!-- Status Indicators -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <View
                        android:id="@+id/statusDot"
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="#CCFF00" />

                    <TextView
                        android:id="@+id/tvActiveMonitoring"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="ACTIVE MONITORING"
                        android:textColor="#CCFF00"
                        android:textSize="10sp"
                        android:fontFamily="@font/space_grotesk_bold"
                        android:letterSpacing="0.1" />
                </LinearLayout>

                <!-- Main Display -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingVertical="4dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/tvDecibelValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="68.4"
                            android:textColor="#CCFF00"
                            android:textSize="96sp"
                            android:fontFamily="@font/space_grotesk_bold"
                            android:letterSpacing="-0.02"
                            android:shadowColor="#CCFF00"
                            android:shadowRadius="15" />

                        <TextView
                            android:id="@+id/tvDecibelUnit"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="dB"
                            android:textColor="#CCFF00"
                            android:textSize="36sp"
                            android:fontFamily="@font/space_grotesk_bold" />
                    </LinearLayout>

                    <!-- Dynamic Noise Level Text -->
                    <TextView
                        android:id="@+id/tvNoiseLevel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/noise_conversation"
                        android:textColor="#CCFF00"
                        android:textSize="14sp"
                        android:fontFamily="@font/space_grotesk_bold" />
                </LinearLayout>

                <!-- Arc Meter -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="32dp"
                    android:paddingTop="16dp">

                    <!-- Scale Labels -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="4dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="0"
                            android:textColor="#666666"
                            android:textSize="8sp"
                            android:fontFamily="@font/space_grotesk_bold" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="20"
                            android:textColor="#666666"
                            android:textSize="8sp"
                            android:gravity="center"
                            android:fontFamily="@font/space_grotesk_bold" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="40"
                            android:textColor="#666666"
                            android:textSize="8sp"
                            android:gravity="center"
                            android:fontFamily="@font/space_grotesk_bold" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="60"
                            android:textColor="#666666"
                            android:textSize="8sp"
                            android:gravity="center"
                            android:fontFamily="@font/space_grotesk_bold" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="80"
                            android:textColor="#666666"
                            android:textSize="8sp"
                            android:gravity="center"
                            android:fontFamily="@font/space_grotesk_bold" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="100"
                            android:textColor="#666666"
                            android:textSize="8sp"
                            android:gravity="center"
                            android:fontFamily="@font/space_grotesk_bold" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="120"
                            android:textColor="#666666"
                            android:textSize="8sp"
                            android:gravity="end"
                            android:fontFamily="@font/space_grotesk_bold" />
                    </LinearLayout>

                    <!-- Progress Bar -->
                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:background="#1C1B1B">

                        <View
                            android:id="@+id/progressBar"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:background="#CCFF00" />

                        <View
                            android:id="@+id/peakMarker"
                            android:layout_width="2dp"
                            android:layout_height="match_parent"
                            android:background="#FFB4AB" />
                    </FrameLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Secondary Metrics Grid -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="#1A1A1A"
                    android:padding="8dp"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MAX PEAK"
                        android:textColor="#666666"
                        android:textSize="10sp"
                        android:fontFamily="@font/space_grotesk_bold"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="2dp" />

                    <TextView
                        android:id="@+id/tvMaxPeak"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="74.2 dB"
                        android:textColor="#CCFF00"
                        android:textSize="16sp"
                        android:fontFamily="@font/space_grotesk_bold"
                        android:letterSpacing="0.05" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="#1A1A1A"
                    android:padding="8dp"
                    android:layout_marginStart="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MIN LEVEL"
                        android:textColor="#666666"
                        android:textSize="10sp"
                        android:fontFamily="@font/space_grotesk_bold"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="2dp" />

                    <TextView
                        android:id="@+id/tvMinLevel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="42.1 dB"
                        android:textColor="#CCFF00"
                        android:textSize="16sp"
                        android:fontFamily="@font/space_grotesk_bold"
                        android:letterSpacing="0.05" />
                </LinearLayout>
            </LinearLayout>

            <!-- Banner Ad -->
            <com.deci.util.BannerAdView
                android:id="@+id/bannerAdView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp" />

            <!-- Spectrum Visualizer -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="154dp"
                android:background="#0A0A0A">

                <com.deci.SpectrumView
                    android:id="@+id/spectrumView"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="4dp" />
            </FrameLayout>
        </LinearLayout>
    </ScrollView>

    <!-- Bottom Navigation -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="#0A0A0A"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- MONITOR Tab -->
        <LinearLayout
            android:id="@+id/navMonitor"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="#CCFF00"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/material_symbols_outlined"
                android:text="graphic_eq"
                android:textColor="#000000"
                android:textSize="24sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/space_grotesk_bold"
                android:text="MONITOR"
                android:textColor="#000000"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- METER Tab -->
        <LinearLayout
            android:id="@+id/navMeter"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="#0A0A0A"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/material_symbols_outlined"
                android:text="speed"
                android:textColor="#71717A"
                android:textSize="24sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/space_grotesk_bold"
                android:letterSpacing="0.05"
                android:text="METER"
                android:textColor="#71717A"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- SYSTEM Tab -->
        <LinearLayout
            android:id="@+id/navSystem"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="#0A0A0A"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/material_symbols_outlined"
                android:text="settings"
                android:textColor="#71717A"
                android:textSize="24sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/space_grotesk_bold"
                android:letterSpacing="0.05"
                android:text="SYSTEM"
                android:textColor="#71717A"
                android:textSize="10sp" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
