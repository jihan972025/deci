<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#131313">

    <!-- Top App Bar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/topAppBar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="#0A0A0A"
        android:elevation="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:contentInsetStart="12dp">

        <TextView
            android:id="@+id/toolbarTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DECI PRO"
            android:textColor="#CCFF00"
            android:textSize="18sp"
            android:fontFamily="@font/space_grotesk_bold"
            android:letterSpacing="-0.05" />
    </com.google.android.material.appbar.MaterialToolbar>

    <!-- Main Content ScrollView -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/topAppBar"
        app:layout_constraintBottom_toTopOf="@id/bottomNav">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_gravity="center_horizontal">

            <!-- CORE SYSTEM STATUS Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:background="#0A0A0A"
                android:orientation="vertical"
                android:padding="12dp">

                <!-- Section Header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingBottom="8dp"
                    android:layout_marginBottom="16dp"
                    android:background="#131313">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="CORE_SYSTEM_STATUS"
                        android:textColor="#666666"
                        android:textSize="10sp"
                        android:fontFamily="@font/space_grotesk_bold"
                        android:letterSpacing="0.1" />

                    <TextView
                        android:id="@+id/stableLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="STABLE"
                        android:textColor="#CCFF00"
                        android:textSize="10sp"
                        android:fontFamily="@font/space_grotesk_bold" />
                </LinearLayout>

                <!-- Battery, Temperature, Storage Grid -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Internal Temperature -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="8dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="INTERNAL_TEMP"
                                android:textColor="#999999"
                                android:textSize="10sp"
                                android:fontFamily="@font/space_grotesk_bold"
                                android:letterSpacing="0.1" />

                            <TextView
                                android:id="@+id/temperatureValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="32.4°C"
                                android:textColor="#CCFF00"
                                android:textSize="16sp"
                                android:fontFamily="@font/space_grotesk_bold"
                                android:letterSpacing="0.05" />
                        </LinearLayout>

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="4dp"
                            android:layout_marginBottom="8dp"
                            android:background="#1A1A1A">

                            <View
                                android:id="@+id/temperatureBar"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:background="#666666" />
                        </FrameLayout>
                    </LinearLayout>

                    <!-- Storage Remaining -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="8dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="STORAGE_REM"
                                android:textColor="#999999"
                                android:textSize="10sp"
                                android:fontFamily="@font/space_grotesk_bold"
                                android:letterSpacing="0.1" />

                            <TextView
                                android:id="@+id/storageValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="124.5 GB"
                                android:textColor="#CCFF00"
                                android:textSize="16sp"
                                android:fontFamily="@font/space_grotesk_bold"
                                android:letterSpacing="0.05" />
                        </LinearLayout>

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="4dp"
                            android:layout_marginBottom="8dp"
                            android:background="#1A1A1A">

                            <View
                                android:id="@+id/storageBar"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:background="#999999" />
                        </FrameLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- NETWORK & DIAGNOSTICS Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#0A0A0A"
                android:orientation="vertical"
                android:padding="12dp">

                <!-- IP Address and Signal Strength Grid -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <!-- IP Address -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:background="#131313"
                        android:orientation="vertical"
                        android:padding="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="IP_ADDRESS"
                            android:textColor="#444444"
                            android:textSize="9sp"
                            android:fontFamily="@font/space_grotesk_bold"
                            android:letterSpacing="0.1"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:id="@+id/ipAddressValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="192.168.1.144"
                            android:textColor="#E5E2E1"
                            android:textSize="12sp"
                            android:fontFamily="@font/space_grotesk_bold" />
                    </LinearLayout>

                    <!-- Signal Strength -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:background="#131313"
                        android:orientation="vertical"
                        android:padding="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SIGNAL_STRENGTH"
                            android:textColor="#444444"
                            android:textSize="9sp"
                            android:fontFamily="@font/space_grotesk_bold"
                            android:letterSpacing="0.1"
                            android:layout_marginBottom="4dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <!-- Signal Bars -->
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="12dp"
                                android:orientation="horizontal"
                                android:layout_marginEnd="8dp"
                                android:gravity="bottom">

                                <View
                                    android:id="@+id/signalBar1"
                                    android:layout_width="4dp"
                                    android:layout_height="4dp"
                                    android:layout_marginEnd="2dp"
                                    android:background="#CCFF00" />

                                <View
                                    android:id="@+id/signalBar2"
                                    android:layout_width="4dp"
                                    android:layout_height="8dp"
                                    android:layout_marginEnd="2dp"
                                    android:background="#CCFF00" />

                                <View
                                    android:id="@+id/signalBar3"
                                    android:layout_width="4dp"
                                    android:layout_height="12dp"
                                    android:layout_marginEnd="2dp"
                                    android:background="#CCFF00" />

                                <View
                                    android:id="@+id/signalBar4"
                                    android:layout_width="4dp"
                                    android:layout_height="8dp"
                                    android:background="#2A2A2A" />
                            </LinearLayout>

                            <TextView
                                android:id="@+id/signalStrengthValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="-64 dBm"
                                android:textColor="#CCFF00"
                                android:textSize="12sp"
                                android:fontFamily="@font/space_grotesk_bold" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- SETTINGS Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="#0A0A0A"
                android:orientation="vertical"
                android:padding="12dp">

                <!-- Language Selection -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="16dp">

                    <Spinner
                        android:id="@+id/languageSpinner"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:background="#131313"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:popupBackground="#131313" />
                </LinearLayout>

                <!-- Color Selection -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Color Chips Grid -->
                    <GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:columnCount="6"
                        android:rowCount="1"
                        android:alignmentMode="alignBounds"
                        android:useDefaultMargins="false">

                        <!-- Lime (default #CCFF00) -->
                        <View
                            android:id="@+id/colorLime"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:layout_columnWeight="1"
                            android:layout_gravity="center"
                            android:layout_margin="4dp"
                            android:background="@drawable/color_chip_circle"
                            android:backgroundTint="#CCFF00"
                            android:clickable="true"
                            android:focusable="true" />

                        <!-- Magenta -->
                        <View
                            android:id="@+id/colorMagenta"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:layout_columnWeight="1"
                            android:layout_gravity="center"
                            android:layout_margin="4dp"
                            android:background="@drawable/color_chip_circle"
                            android:backgroundTint="#FF00FF"
                            android:clickable="true"
                            android:focusable="true" />

                        <!-- Cyan -->
                        <View
                            android:id="@+id/colorCyan"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:layout_columnWeight="1"
                            android:layout_gravity="center"
                            android:layout_margin="4dp"
                            android:background="@drawable/color_chip_circle"
                            android:backgroundTint="#00FFFF"
                            android:clickable="true"
                            android:focusable="true" />

                        <!-- Orange -->
                        <View
                            android:id="@+id/colorOrange"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:layout_columnWeight="1"
                            android:layout_gravity="center"
                            android:layout_margin="4dp"
                            android:background="@drawable/color_chip_circle"
                            android:backgroundTint="#FF5F1F"
                            android:clickable="true"
                            android:focusable="true" />

                        <!-- Hot Pink -->
                        <View
                            android:id="@+id/colorHotPink"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:layout_columnWeight="1"
                            android:layout_gravity="center"
                            android:layout_margin="4dp"
                            android:background="@drawable/color_chip_circle"
                            android:backgroundTint="#FF1493"
                            android:clickable="true"
                            android:focusable="true" />

                        <!-- Spring Green -->
                        <View
                            android:id="@+id/colorSpringGreen"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:layout_columnWeight="1"
                            android:layout_gravity="center"
                            android:layout_margin="4dp"
                            android:background="@drawable/color_chip_circle"
                            android:backgroundTint="#39FF14"
                            android:clickable="true"
                            android:focusable="true" />

                    </GridLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Banner Ad -->
            <com.deci.util.BannerAdView
                android:id="@+id/bannerAdView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="#131313" />

            <!-- APP INFO Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="#0A0A0A"
                android:orientation="vertical"
                android:padding="12dp">

                <!-- App Name -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="APP_NAME"
                        android:textColor="#999999"
                        android:textSize="10sp"
                        android:fontFamily="@font/space_grotesk_bold"
                        android:letterSpacing="0.1" />

                    <TextView
                        android:id="@+id/appNameValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DECI PRO"
                        android:textColor="#CCFF00"
                        android:textSize="16sp"
                        android:fontFamily="@font/space_grotesk_bold"
                        android:letterSpacing="0.05" />
                </LinearLayout>

                <!-- Version -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="VERSION"
                        android:textColor="#999999"
                        android:textSize="10sp"
                        android:fontFamily="@font/space_grotesk_bold"
                        android:letterSpacing="0.1" />

                    <TextView
                        android:id="@+id/versionValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1.0.0"
                        android:textColor="#CCFF00"
                        android:textSize="16sp"
                        android:fontFamily="@font/space_grotesk_bold"
                        android:letterSpacing="0.05" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- Bottom Navigation -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="#0A0A0A"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- MONITOR Tab -->
        <LinearLayout
            android:id="@+id/navMonitor"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="#0A0A0A"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/material_symbols_outlined"
                android:text="graphic_eq"
                android:textColor="#71717A"
                android:textSize="24sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/space_grotesk_bold"
                android:text="MONITOR"
                android:textColor="#71717A"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- METER Tab -->
        <LinearLayout
            android:id="@+id/navMeter"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="#0A0A0A"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/material_symbols_outlined"
                android:text="speed"
                android:textColor="#71717A"
                android:textSize="24sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/space_grotesk_bold"
                android:letterSpacing="0.05"
                android:text="METER"
                android:textColor="#71717A"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- SYSTEM Tab -->
        <LinearLayout
            android:id="@+id/navSystem"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="#CCFF00"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/material_symbols_outlined"
                android:text="settings"
                android:textColor="#000000"
                android:textSize="24sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/space_grotesk_bold"
                android:letterSpacing="0.05"
                android:text="SYSTEM"
                android:textColor="#000000"
                android:textSize="10sp" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
