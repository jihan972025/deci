<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#131313">

    <!-- Top App Bar -->
    <LinearLayout
        android:id="@+id/topAppBar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="#0A0A0A"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/toolbarTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DECI PRO"
            android:textColor="#CCFF00"
            android:textSize="18sp"
            android:fontFamily="@font/space_grotesk_bold"
            android:letterSpacing="-0.02" />
    </LinearLayout>

    <!-- WebView for displaying meter.html -->
    <WebView
        android:id="@+id/webView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="#131313"
        app:layout_constraintTop_toBottomOf="@id/topAppBar"
        app:layout_constraintBottom_toTopOf="@id/bannerAdView" />

    <!-- Banner Ad -->
    <com.deci.util.BannerAdView
        android:id="@+id/bannerAdView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#131313"
        app:layout_constraintBottom_toTopOf="@id/bottomNav" />

    <!-- Bottom Navigation -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="#0A0A0A"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- MONITOR Tab -->
        <LinearLayout
            android:id="@+id/navMonitor"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="#0A0A0A"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/material_symbols_outlined"
                android:text="graphic_eq"
                android:textColor="#71717A"
                android:textSize="24sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/space_grotesk_bold"
                android:text="MONITOR"
                android:textColor="#71717A"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- METER Tab -->
        <LinearLayout
            android:id="@+id/navMeter"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="#CCFF00"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/material_symbols_outlined"
                android:text="speed"
                android:textColor="#000000"
                android:textSize="24sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/space_grotesk_bold"
                android:letterSpacing="0.05"
                android:text="METER"
                android:textColor="#000000"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- SYSTEM Tab -->
        <LinearLayout
            android:id="@+id/navSystem"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="#0A0A0A"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/material_symbols_outlined"
                android:text="settings"
                android:textColor="#71717A"
                android:textSize="24sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/space_grotesk_bold"
                android:letterSpacing="0.05"
                android:text="SYSTEM"
                android:textColor="#71717A"
                android:textSize="10sp" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
